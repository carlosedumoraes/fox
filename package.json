{
  "name": "fox",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "dev:backend": "mvn -f apps/backend/pom.xml spring-boot:run",
    "build": "turbo run build",
    "build:frontend": "npm run build --workspace=apps/frontend",
    "build:backend": "mvn -f apps/backend/pom.xml clean package -DskipTests -B"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "packageManager": "npm@10.9.0"
}
